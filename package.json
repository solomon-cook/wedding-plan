{
  "name": "wedding-day-planner",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "db:setup": "rm -f prisma/dev.db && sqlite3 prisma/dev.db < prisma/migrations/20260609163200_init/migration.sql && prisma generate && prisma db seed",
